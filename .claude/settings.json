{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo rm *)",
      "Bash(mkfs*)",
      "Bash(dd if=* of=/dev/*)",
      "Bash(chmod -R 777 /*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  }
}